{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32Cube: Launch ST-Link GDB Server",
            "type": "stlinkgdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "preBuild": "${command:st-stm32-ide-debug-launch.build}",
            "runEntry": "main",
            "imagesAndSymbols": [
                {
                    "imageFileName": "${command:st-stm32-ide-debug-launch.get-projects-binary-from-context1}"
                }
            ],
            "serverInterface": "SWD",
            "serverInterfaceFrequency": "Auto",
            "serverVerify": false,
            "gdbAsync": true,
            "gdbNonStop": false,
            "verbose": false,
            "logFile": "${workspaceFolder}/gdbClient_log.txt"
        }
    ]
}
