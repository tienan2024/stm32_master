#include "{{MODULE_NAME}}.h"
#include "tim.h"

static TIM_HandleTypeDef *{{MODULE_NAME}}_htim = NULL;
static uint32_t {{MODULE_NAME}}_channel = 0;

/**
 * @brief {{MODULE_NAME}}初始化
 * @param htim 定时器句柄
 * @param channel PWM 通道 (1-4)
 * @return 0: 成功, -1: 失败
 */
int {{MODULE_NAME}}_init(TIM_HandleTypeDef *htim, uint32_t channel)
{
    {{MODULE_NAME}}_htim = htim;
    {{MODULE_NAME}}_channel = channel;
    /* TODO: 添加初始化代码 */
    return 0;
}

/**
 * @brief {{MODULE_NAME}}启动 PWM
 */
void {{MODULE_NAME}}_pwm_start(void)
{
    HAL_TIM_PWM_Start({{MODULE_NAME}}_htim, {{MODULE_NAME}}_channel);
}

/**
 * @brief {{MODULE_NAME}}停止 PWM
 */
void {{MODULE_NAME}}_pwm_stop(void)
{
    HAL_TIM_PWM_Stop({{MODULE_NAME}}_htim, {{MODULE_NAME}}_channel);
}

/**
 * @brief {{MODULE_NAME}}设置占空比
 * @param duty 占空比 (0-1000, 代表 0.0%-100.0%)
 */
void {{MODULE_NAME}}_set_duty(uint16_t duty)
{
    uint32_t period = {{MODULE_NAME}}_htim->Instance->ARR;
    uint32_t pulse = (period * duty) / 1000;
    __HAL_TIM_SET_COMPARE({{MODULE_NAME}}_htim, {{MODULE_NAME}}_channel, pulse);
}

/**
 * @brief {{MODULE_NAME}}设置频率
 * @param freq 频率 (Hz)
 */
void {{MODULE_NAME}}_set_freq(uint32_t freq)
{
    uint32_t pclk = HAL_RCC_GetPCLK1Freq();
    uint32_t period = (pclk / freq) - 1;
    __HAL_TIM_SET_AUTORELOAD({{MODULE_NAME}}_htim, period);
    {{MODULE_NAME}}_set_duty(500);  /* 默认 50% 占空比 */
}
