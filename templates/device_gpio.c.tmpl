#include "{{MODULE_NAME}}.h"
#include "gpio.h"

/* GPIO 定义 */
#define {{MODULE_NAME_UPPER}}_PORT  GPIOA
#define {{MODULE_NAME_UPPER}}_PIN   GPIO_PIN_0

static GPIO_TypeDef *{{MODULE_NAME}}_port = {{MODULE_NAME_UPPER}}_PORT;
static uint16_t {{MODULE_NAME}}_pin = {{MODULE_NAME_UPPER}}_PIN;

/**
 * @brief {{MODULE_NAME}}初始化
 * @param port GPIO 端口
 * @param pin GPIO 引脚编号
 */
void {{MODULE_NAME}}_init(GPIO_TypeDef *port, uint16_t pin)
{
    {{MODULE_NAME}}_port = port;
    {{MODULE_NAME}}_pin = pin;
    /* TODO: 添加初始化代码 */
}

/**
 * @brief {{MODULE_NAME}}设置输出状态
 * @param state 0: 低, 1: 高
 */
void {{MODULE_NAME}}_set(uint8_t state)
{
    HAL_GPIO_WritePin({{MODULE_NAME}}_port, {{MODULE_NAME}}_pin, state ? GPIO_PIN_SET : GPIO_PIN_RESET);
}

/**
 * @brief {{MODULE_NAME}}获取输入状态
 * @return 0: 低, 1: 高
 */
uint8_t {{MODULE_NAME}}_get(void)
{
    return HAL_GPIO_ReadPin({{MODULE_NAME}}_port, {{MODULE_NAME}}_pin) == GPIO_PIN_SET ? 1 : 0;
}

/**
 * @brief {{MODULE_NAME}}翻转输出状态
 */
void {{MODULE_NAME}}_toggle(void)
{
    HAL_GPIO_TogglePin({{MODULE_NAME}}_port, {{MODULE_NAME}}_pin);
}
