{
  "name": "stm32-serial-monitor",
  "displayName": "STM32 Serial Monitor",
  "description": "Real-time serial port monitoring for STM32 devices with WebView UI in VS Code",
  "version": "1.0.0",
  "author": "STM32 Developer",
  "license": "MIT",
  "publisher": "stm32dev",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "STM32",
    "serial",
    "UART",
    "embedded",
    "monitor"
  ],
    "main": "./out/extension.js",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "views": {
      "serialMonitor": [
        {
          "id": "serialMonitorView",
          "name": "Serial Monitor",
          "type": "webview",
          "contextualTitle": "STM32 Serial Monitor",
          "icon": "$(plug)"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "serialMonitor",
          "title": "Serial Monitor",
          "icon": "$(plug)"
        }
      ]
    },
    "commands": [
      {
        "command": "stm32-serial-monitor.open",
        "title": "Open Serial Monitor",
        "category": "STM32"
      },
      {
        "command": "stm32-serial-monitor.startMonitoring",
        "title": "Start Monitoring",
        "category": "STM32",
        "icon": "$(play)"
      },
      {
        "command": "stm32-serial-monitor.stopMonitoring",
        "title": "Stop Monitoring",
        "category": "STM32",
        "icon": "$(stop)"
      },
      {
        "command": "stm32-serial-monitor.clearOutput",
        "title": "Clear Output",
        "category": "STM32",
        "icon": "$(clear-all)"
      },
      {
        "command": "stm32-serial-monitor.downloadLog",
        "title": "Download Log",
        "category": "STM32",
        "icon": "$(download)"
      },
      {
        "command": "stm32-serial-monitor.selectPort",
        "title": "Select COM Port",
        "category": "STM32"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "stm32-serial-monitor.startMonitoring",
          "when": "view == serialMonitorView",
          "group": "navigation@1"
        },
        {
          "command": "stm32-serial-monitor.stopMonitoring",
          "when": "view == serialMonitorView",
          "group": "navigation@2"
        },
        {
          "command": "stm32-serial-monitor.clearOutput",
          "when": "view == serialMonitorView",
          "group": "navigation@3"
        },
        {
          "command": "stm32-serial-monitor.downloadLog",
          "when": "view == serialMonitorView",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "STM32 Serial Monitor",
      "properties": {
        "stm32.serialMonitor.port": {
          "type": "string",
          "default": "",
          "description": "Serial port to monitor (e.g., COM3)"
        },
        "stm32.serialMonitor.baudRate": {
          "type": "number",
          "default": 115200,
          "description": "Baud rate for serial communication"
        },
        "stm32.serialMonitor.dataBits": {
          "type": "number",
          "default": 8,
          "enum": [
            5,
            6,
            7,
            8
          ],
          "description": "Number of data bits"
        },
        "stm32.serialMonitor.stopBits": {
          "type": "number",
          "default": 1,
          "enum": [
            1,
            2
          ],
          "description": "Number of stop bits"
        },
        "stm32.serialMonitor.parity": {
          "type": "string",
          "default": "none",
          "enum": [
            "none",
            "odd",
            "even"
          ],
          "description": "Parity type"
        },
        "stm32.serialMonitor.autoScroll": {
          "type": "boolean",
          "default": true,
          "description": "Auto-scroll to latest message"
        },
        "stm32.serialMonitor.maxLines": {
          "type": "number",
          "default": 5000,
          "description": "Maximum number of lines to keep in buffer"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^7.2.0",
    "@types/mocha": "^9.1.1",
    "@types/node": "^16.18.126",
    "@types/serialport": "^8.0.5",
    "@types/vscode": "^1.70.0",
    "@typescript-eslint/eslint-plugin": "^5.31.0",
    "@typescript-eslint/parser": "^5.31.0",
    "@vscode/test-electron": "^2.1.5",
    "eslint": "^8.20.0",
    "glob": "^8.0.3",
    "mocha": "^10.0.1",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "serialport": "^9.2.8"
  }
}
